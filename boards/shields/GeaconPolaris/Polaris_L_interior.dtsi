#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/zmk/zip_dynamic_scale.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/keys.h>
#include <input/processors/runtime-input-processor.dtsi>

/ {
    zip_keybind_keys: zip_keybind_keys {
        compatible = "zmk,input-processor-keybind";
        #input-processor-cells = <0>;
        track_remainders;
        bindings = <&kp RIGHT>,
                   <&kp LEFT>,
                   <&kp UP>,
                   <&kp DOWN>;
        tick = <40>;
        wait-ms = <0>;
        tap-ms = <10>;
    };

    iqs_dynamic_xy_scaler: iqs_dynamic_xy_scaler {
        compatible = "zmk,input-processor-dynamic-scaler";
        #input-processor-cells = <0>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_X INPUT_REL_Y>;
        scale-group = <ZDS_XY>;
        track-remainders;
    };

    iqs_dynamic_scroll_scaler: iqs_dynamic_scroll_scaler {
        compatible = "zmk,input-processor-dynamic-scaler";
        #input-processor-cells = <0>;
        type = <INPUT_EV_REL>;
        codes = <INPUT_REL_WHEEL INPUT_REL_HWHEEL>;
        scale-group = <ZDS_SC>;
        track-remainders;
    };

    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        trackball_split: trackball_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };

        stick_split: stick_split@2 {
            compatible = "zmk,input-split";
            reg = <2>;
        };

        trackpad_split: trackpad_split@3 {
            compatible = "zmk,input-split";
            reg = <3>;
        };

        iqs_split: iqs_split@4 {
            compatible = "zmk,input-split";
            reg = <4>;
        };
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&trackball_split>;
            // input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>,
            //                    <&zip_xy_scaler 2 3>;
        input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>,
                           <&mouse_runtime_input_processor>;

        scroll {
            layers = <1>;
            input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>,
                               <&scroll_runtime_input_processor_r>;
            process-next;
        };

        arrow {
            layers = <2>;
            input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>,
                               <&mouse_runtime_input_processor>,
                               <&zip_keybind_keys>;
            process-next;
        };

        arrow-prevent-move {
            layers = <2>;
            input-processors = <&zip_xy_scaler 0 1>;
        };

        snipe {
            layers = <3>;
            input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_X_INVERT)>,
                               <&mouse_runtime_input_processor>,
                               <&zip_xy_scaler 1 3>;
        };
    };

    iqs_listener: iqs_listener {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&iqs_split>;
        input-processors = <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>,
                           <&zip_xy_scaler 1 12>,
                           <&zip_scroll_scaler 1 40>,
                           <&iqs_dynamic_xy_scaler>,
                           <&iqs_dynamic_scroll_scaler>;

        lowspeedmode {
            layers = <1>, <2>;
            input-processors = <&zip_xy_transform INPUT_TRANSFORM_X_INVERT>,
                               <&zip_xy_scaler 1 24>,
                               <&zip_scroll_scaler 1 60>,
                               <&iqs_dynamic_xy_scaler>,
                               <&iqs_dynamic_scroll_scaler>;
        };
    };


    trackpad_listener: trackpad_listener {
        compatible = "zmk,input-listener";
        status = "okay";
        device = <&trackpad_split>;

        input-processors = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT)>,
                           <&mouse_runtime_input_processor>,
                           <&zip_xy_scaler 1 5>,
                           <&zip_scroll_scaler 1 50>;

        lowspeedmode {
            layers = <1>, <2>;
            input-processors = <&zip_xy_transform (INPUT_TRANSFORM_X_INVERT)>,
                               <&mouse_runtime_input_processor>,
                               <&zip_xy_scaler 1 12>,
                               <&zip_scroll_scaler 1 70>;
        };
    };

	scroll_runtime_input_processor_r: scroll_runtime_input_processor_r {
		compatible = "zmk,input-processor-runtime";
        processor-label = "ScrR";
		type = <INPUT_EV_REL>;
		track-remainders;
		scale-divisor = <60>;
		#input-processor-cells = <0>;
	};
};

&scroll_runtime_input_processor_r {
        x-codes = <INPUT_REL_X>;
        y-codes = <INPUT_REL_Y>;
        xy-to-scroll-enabled;
};
